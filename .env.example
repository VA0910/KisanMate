# KisanMate local environment — copy this to `.env` and fill in your values.
#   cp .env.example .env
# `.env` is gitignored; never commit real keys. On Cloud Run these come from the
# service config instead, and any values set there override this file.

# --- Gemini (AI content layer) ------------------------------------------------
# By default (GEMINI_USE_VERTEXAI=true) Gemini calls go through Vertex AI, billed
# to GOOGLE_CLOUD_PROJECT's Google Cloud billing account (covered by Free Trial
# credits, unlike the AI Studio Developer API below). This needs no API key --
# just GOOGLE_CLOUD_PROJECT (set below under Firestore) and the runtime identity
# having the "Vertex AI User" role on that project.
# GEMINI_USE_VERTEXAI=true
# GEMINI_VERTEX_LOCATION=asia-south1
#
# To use the AI Studio Developer API instead (e.g. no GCP project set up locally),
# set GEMINI_USE_VERTEXAI=false and provide the key EITHER directly (A) or via
# Google Secret Manager (B).
#
#   A) Directly (simplest for local dev). Get a key from
#      https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key-here
#
#   B) From Google Secret Manager (recommended for deployment; leave GEMINI_API_KEY
#      unset to use this). Set GEMINI_API_KEY_SECRET to either a short secret id
#      (resolved against GOOGLE_CLOUD_PROJECT) or a full version resource name.
#      The runtime identity needs the "Secret Manager Secret Accessor" role.
# GEMINI_API_KEY_SECRET=gemini-api-key
# GEMINI_API_KEY_SECRET=projects/your-gcp-project-id/secrets/gemini-api-key/versions/latest
#      Optional: override the project the short id resolves against.
# GEMINI_API_KEY_SECRET_PROJECT=your-gcp-project-id

# Optional. Which Gemini model the vision + explain calls use.
# Defaults to gemini-2.5-flash if unset; swap here to try another Flash model.
GEMINI_MODEL=gemini-3.5-flash

# --- Firestore (database) -----------------------------------------------------
# On Cloud Run auth is automatic (no key files). For LOCAL development, pick ONE:
#
#   A) gcloud Application Default Credentials (recommended, no key file):
#        gcloud auth application-default login
#        gcloud config set project <your-project-id>
#      Then set the project id so the Firestore client knows which project to use:
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
#
#   B) A service-account key file (service-account*.json is gitignored):
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# --- Mandi prices (assistant's mandi_price intent, mandi.py) ------------------
# Free key from https://data.gov.in (Sign Up -> My Account -> API Keys). Without
# it, the assistant just answers "no rate available" for price questions --
# it never fails loudly or fabricates a price.
# DATA_GOV_API_KEY=your-data-gov-in-api-key-here
#
# Persistent mandi-price cache (mandi.py, firestore_client.py): once
# GOOGLE_CLOUD_PROJECT (set above) is configured, price lookups are cached in
# Firestore for 24h -- data.gov.in's Agmarknet rows only change once a day
# anyway, so this is never stale relative to the source. No extra config needed.
#
# Daily pre-warm (mandi_prewarm.py): refreshes the cache once a day for every
# (commodity, district) a real farmer is actually in/growing, so their first
# query of the day doesn't wait on a live data.gov.in call. Wire a Cloud
# Scheduler job (or, locally, a cron/manual curl) to POST
# /api/admin/mandi/refresh-cache once daily with header
# "X-Cron-Secret: $MANDI_CRON_SECRET". Leaving MANDI_CRON_SECRET unset disables
# the endpoint entirely (returns 401) -- everything still works without it,
# just via the on-demand cache above instead of a proactive daily refresh.
# MANDI_CRON_SECRET=some-long-random-string
